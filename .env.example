# ── Instagram (Meta Graph API) ──────────────────────────────
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=      # Long-lived token (60-day expiry — auto-refreshes)
INSTAGRAM_USER_ID=           # Your IG Business account ID
INSTAGRAM_API_VERSION=v21.0

# ── TikTok (Third-Party API) ─────────────────────────────────
# Use ONE of the two options below:

# Option A — EnsembleData (covers IG + TT, $100+/mo)
ENSEMBLEDATA_API_TOKEN=

# Option B — LamaTok (TikTok-only, ~$0.0006/req, 100 free)
LAMATOK_API_KEY=

# ── Email (SendGrid) ─────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=trends@yourdomain.com
EMAIL_TO=you@yourdomain.com           # Comma-separate for multiple recipients

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Tracking ─────────────────────────────────────────────────
HASHTAGS_TO_TRACK=skincare,aestheticfashion,cottagecore,cleanbeauty
TIKTOK_REGIONS=GB,US                  # ISO country codes

# ── Scheduler ────────────────────────────────────────────────
TIMEZONE=Europe/London

# ── App ──────────────────────────────────────────────────────
LOG_FILE=data/trends_log.json
